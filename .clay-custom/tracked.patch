+    var turnStarts = messagesEl.querySelectorAll(".msg-assistant.msg-turn-start");
+    expect(turnStarts.length).toBe(3);
+  });
+
+  it("tool calls within a turn don't create extra index entries", function () {
+    app.addUserMessage("Use tools");

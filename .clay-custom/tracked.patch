+  width: 6px;
+  height: 6px;
+}
+
+/* Hide position counter & separator — save vertical space in sidecar */
+.nav-docked .msg-nav-pos {
+  display: none;
+}
+
+.nav-docked .msg-nav-sep {
+  display: none;
+}
+
+/* --- Typing mode: hide sidecar, restore full input width ---
+   .mobile-typing is set by modules/mobile-mode.js on #app
+   when the user focuses the input textarea on a mobile device. */
+
+.mobile-typing #input-row {
+  margin-right: 0;
+}
+
+.mobile-typing .msg-nav-rail {
+  display: none;
+}
+
+/* --- Narrow desktop where content fills the viewport ---
+   When #app is narrower than content-width + rail, fall back to right edge */
+@media (max-width: 900px) and (min-width: 769px) {
+  .msg-nav-rail {
+    right: 8px;
+  }
+}
